  "bugs": {
    "url": "https://github.com/swapnilahmedshishir/erp-server/issues"
  },
  "homepage": "https://github.com/swapnilahmedshishir/erp-server#readme",
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "http-status": "^2.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.3",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "streamifier": "^0.1.1",
    "uuid": "^14.0.1",
